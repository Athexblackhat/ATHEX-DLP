<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base Application Theme -->
    <style name="Theme.ATHEXDLP" parent="Theme.AppCompat.DayNight.NoActionBar">
        <!-- Primary Colors -->
        <item name="colorPrimary">@color/accent_cyan</item>
        <item name="colorPrimaryDark">@color/bg_primary</item>
        <item name="colorAccent">@color/accent_purple</item>
        
        <!-- Background -->
        <item name="android:windowBackground">@color/bg_primary</item>
        <item name="android:colorBackground">@color/bg_primary</item>
        
        <!-- Status Bar -->
        <item name="android:statusBarColor">@color/bg_primary</item>
        <item name="android:navigationBarColor">@color/bg_primary</item>
        <item name="android:windowLightStatusBar">false</item>
        
        <!-- Text -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        
        <!-- Action Bar -->
        <item name="actionBarStyle">@style/ATHEXActionBar</item>
        <item name="android:actionBarStyle">@style/ATHEXActionBar</item>
    </style>
    
    <!-- Action Bar Style -->
    <style name="ATHEXActionBar" parent="Widget.AppCompat.ActionBar">
        <item name="background">@color/bg_secondary</item>
        <item name="titleTextStyle">@style/ATHEXActionBarTitle</item>
        <item name="elevation">0dp</item>
    </style>
    
    <!-- Action Bar Title -->
    <style name="ATHEXActionBarTitle" parent="TextAppearance.AppCompat.Widget.ActionBar.Title">
        <item name="android:textColor">@color/accent_cyan</item>
        <item name="android:textSize">18sp</item>
    </style>
    
    <!-- Splash Screen Theme -->
    <style name="Theme.ATHEXDLP.Splash" parent="Theme.ATHEXDLP">
        <item name="android:windowBackground">@color/bg_primary</item>
        <item name="android:statusBarColor">@color/bg_primary</item>
    </style>
    
    <!-- Dialog Theme -->
    <style name="ATHEXDialog" parent="Theme.AppCompat.DayNight.Dialog.Alert">
        <item name="colorPrimary">@color/accent_cyan</item>
        <item name="android:background">@color/bg_card</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
    </style>
    
    <!-- Button Styles -->
    <style name="ATHEXButton" parent="Widget.AppCompat.Button">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:backgroundTint">@color/accent_cyan</item>
    </style>
    
    <style name="ATHEXButton.Danger">
        <item name="android:backgroundTint">@color/accent_red</item>
    </style>
    
    <style name="ATHEXButton.Success">
        <item name="android:backgroundTint">@color/accent_green</item>
    </style>
</resources>